{
  "compilerOptions": {
    "lib": [
      "ESNext",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "strict": true,
    "target": "ES2022",
    "types": [
      "node"
    ]
  },
  "include": [
    "generated/**/*.ts",
    "playwright.config.ts",
    "showcase/**/*.d.ts",
    "tests/**/*.ts",
    "tooling/**/*.ts",
    "vite.config.tooling.ts"
  ]
}
